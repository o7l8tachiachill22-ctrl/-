<style>
:root {
  --ink: #2a2018;
  --warm: #7a5c3a;
  --light-warm: #c9a97a;
  --bg: #fdf8f2;
  --bg2: #f5ede0;
  --white: #fff;
  --orange: #d95f2b;
  --green: #4a7c59;
  --text: #3d3025;
  --muted: #8a7060;
  --border: #e2d4c0;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Noto Sans JP', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.8;
}

/* HEADER */
header {
  background: var(--white);
  border-bottom: 2px solid var(--border);
  padding: 0 24px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}

.logo-img {
  width: 44px;
  height: 44px;
  object-fit: contain;
}

.logo-text {
  font-family: 'Noto Serif JP', serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.2;
}

.logo-text small {
  display: block;
  font-size: 10px;
  color: var(--muted);
  font-family: 'Noto Sans JP', sans-serif;
  font-weight: 400;
  letter-spacing: 1px;
  margin-top: 2px;
}

nav {
  display: flex;
  gap: 2px;
}

nav a {
  color: var(--muted);
  text-decoration: none;
  font-size: 13px;
  padding: 8px 14px;
  border-radius: 6px;
  transition: all 0.2s;
}

nav a:hover {
  background: var(--bg2);
  color: var(--warm);
}

/* HERO — 個人ブログらしいあたたかいトップ */
.hero {
  background: var(--bg2);
  padding: 60px 24px 0;
  overflow: hidden;
}

.hero-inner {
  max-width: 1000px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: flex-end;
}

.hero-text {
  padding-bottom: 60px;
}

.hero-kicker {
  display: inline-block;
  background: var(--orange);
  color: white;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  padding: 4px 14px;
  border-radius: 100px;
  margin-bottom: 20px;
}

.hero-title {
  font-family: 'Noto Serif JP', serif;
  font-size: clamp(26px, 4vw, 44px);
  font-weight: 700;
  color: var(--ink);
  line-height: 1.5;
  margin-bottom: 20px;
}

.hero-title .underline {
  position: relative;
  display: inline;
}

.hero-title .underline::after {
  content: '';
  position: absolute;
  bottom: 2px;
  left: 0;
  right: 0;
  height: 8px;
  background: rgba(217, 95, 43, 0.25);
  z-index: -1;
}

.hero-lead {
  font-size: 15px;
  color: var(--muted);
  line-height: 2;
  max-width: 480px;
  margin-bottom: 32px;
}

.hero-lead strong {
  color: var(--text);
  font-weight: 700;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 36px;
}

.hero-tag {
  background: var(--white);
  border: 1.5px solid var(--border);
  color: var(--warm);
  font-size: 12px;
  font-weight: 700;
  padding: 5px 14px;
  border-radius: 100px;
}

.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--orange);
  color: white;
  font-weight: 700;
  font-size: 15px;
  padding: 14px 28px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.2s;
  box-shadow: 0 4px 16px rgba(217,95,43,0.3);
}

.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(217,95,43,0.4);
}

.hero-logo-area {
  width: 300px;
  flex-shrink: 0;
  align-self: flex-end;
}

.hero-logo-area img {
  width: 100%;
  display: block;
  filter: drop-shadow(0 8px 24px rgba(0,0,0,0.12));
}

/* WHAT IS THIS BLOG */
.intro-strip {
  background: var(--orange);
  padding: 20px 24px;
}

.intro-strip-inner {
  max-width: 1000px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.intro-strip-icon {
  font-size: 28px;
}

.intro-strip p {
  color: white;
  font-size: 14px;
  font-weight: 500;
  line-height: 1.7;
}

.intro-strip strong {
  font-weight: 900;
}

/* ABOUT */
.about {
  max-width: 1000px;
  margin: 0 auto;
  padding: 80px 24px;
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 56px;
  align-items: start;
}

.about-body h2 {
  font-family: 'Noto Serif JP', serif;
  font-size: 26px;
  font-weight: 700;
  margin-bottom: 20px;
  color: var(--ink);
  line-height: 1.5;
}

.about-body p {
  color: var(--muted);
  font-size: 15px;
  margin-bottom: 16px;
  line-height: 2;
}

.about-body p strong {
  color: var(--text);
}

.profile-box {
  background: var(--white);
  border: 2px solid var(--border);
  border-radius: 16px;
  padding: 28px 24px;
  position: sticky;
  top: 84px;
}

.profile-box-top {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}

.profile-icon {
  width: 64px;
  height: 64px;
  object-fit: contain;
  border-radius: 50%;
  background: var(--bg2);
  padding: 4px;
}

.profile-name-area {
  font-weight: 700;
  font-size: 16px;
  color: var(--ink);
  line-height: 1.3;
}

.profile-name-area small {
  display: block;
  font-size: 12px;
  color: var(--muted);
  font-weight: 400;
  margin-top: 4px;
}

.profile-box p {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.9;
  margin-bottom: 16px;
}

.profile-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.chip {
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 100px;
  background: var(--bg2);
  color: var(--warm);
}

/* FOR YOU */
.for-you {
  background: var(--bg2);
  padding: 72px 24px;
}

.for-you-inner {
  max-width: 1000px;
  margin: 0 auto;
}

.section-heading {
  font-family: 'Noto Serif JP', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 8px;
}

.section-sub {
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 36px;
}

.for-you-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.for-you-card {
  background: var(--white);
  border-radius: 14px;
  padding: 28px 22px;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.for-you-card:hover {
  border-color: var(--light-warm);
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(122,92,58,0.1);
}

.fy-icon {
  font-size: 36px;
  margin-bottom: 14px;
  display: block;
}

.fy-title {
  font-weight: 700;
  font-size: 16px;
  margin-bottom: 10px;
  color: var(--ink);
}

.fy-desc {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.8;
}

/* BEFORE/AFTER */
.ba {
  max-width: 1000px;
  margin: 0 auto;
  padding: 80px 24px;
}

.ba-grid {
  display: grid;
  grid-template-columns: 1fr 56px 1fr;
  gap: 0;
  align-items: center;
  margin-top: 36px;
}

.ba-card {
  border-radius: 14px;
  overflow: hidden;
  position: relative;
}

.ba-card img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
}

.ba-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 2px;
  padding: 4px 14px;
  border-radius: 100px;
}

.ba-badge.before { background: rgba(0,0,0,0.55); color: white; }
.ba-badge.after { background: var(--green); color: white; }

.ba-caption {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.65));
  color: white;
  font-size: 13px;
  font-weight: 500;
  padding: 20px 16px 12px;
}

.ba-arrow-cell {
  text-align: center;
  color: var(--orange);
  font-size: 28px;
  font-weight: 900;
}

.ba-note {
  margin-top: 20px;
  font-size: 13px;
  color: var(--muted);
  text-align: center;
  line-height: 1.8;
}

/* WORK SCENE */
.scene {
  background: var(--bg2);
  padding: 72px 24px;
}

.scene-inner {
  max-width: 1000px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}

.scene-img-wrap {
  position: relative;
}

.scene-img-main {
  width: 100%;
  border-radius: 16px;
  display: block;
  box-shadow: 0 8px 32px rgba(0,0,0,0.12);
}

.scene-img-float {
  position: absolute;
  bottom: -20px;
  right: -20px;
  width: 44%;
  border-radius: 12px;
  border: 4px solid var(--white);
  box-shadow: 0 4px 20px rgba(0,0,0,0.15);
}

.scene-text h2 {
  font-family: 'Noto Serif JP', serif;
  font-size: 24px;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.6;
  margin-bottom: 20px;
}

.scene-text p {
  font-size: 14px;
  color: var(--muted);
  line-height: 2;
  margin-bottom: 16px;
}

.scene-text strong {
  color: var(--text);
}

.promise-list {
  list-style: none;
  margin-top: 24px;
}

.promise-list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 14px;
  color: var(--muted);
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
  line-height: 1.7;
}

.promise-list li:last-child { border-bottom: none; }

.promise-check {
  color: var(--green);
  font-size: 18px;
  flex-shrink: 0;
  margin-top: 2px;
}

/* TOPICS */
.topics {
  max-width: 1000px;
  margin: 0 auto;
  padding: 80px 24px;
}

.topic-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-top: 36px;
}

.topic-card {
  background: var(--white);
  border: 2px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  text-decoration: none;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 16px;
  transition: all 0.2s;
}

.topic-card:hover {
  border-color: var(--light-warm);
  background: var(--bg2);
}

.topic-soon {
  opacity: 0.6;
  cursor: default;
  pointer-events: none;
}

.soon-badge {
  display: inline-block;
  background: var(--border);
  color: var(--muted);
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 100px;
  vertical-align: middle;
  margin-left: 6px;
  letter-spacing: 1px;
}

.topic-icon {
  font-size: 28px;
  flex-shrink: 0;
}

.topic-name {
  font-weight: 700;
  font-size: 15px;
  margin-bottom: 4px;
}

.topic-desc {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.6;
}

/* TIKTOK TEASER */
.tiktok-teaser {
  background: var(--ink);
  padding: 56px 24px;
  text-align: center;
}

.tiktok-teaser-inner {
  max-width: 560px;
  margin: 0 auto;
}

.teaser-badge {
  display: inline-block;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.6);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  padding: 4px 16px;
  border-radius: 100px;
  margin-bottom: 16px;
}

.tiktok-teaser h3 {
  font-family: 'Noto Serif JP', serif;
  font-size: 22px;
  color: white;
  font-weight: 700;
  margin-bottom: 12px;
  line-height: 1.6;
}

.tiktok-teaser p {
  font-size: 14px;
  color: rgba(255,255,255,0.5);
  line-height: 1.9;
}

/* BLOG LINK */
.blog-link-sec {
  background: var(--bg2);
  padding: 72px 24px;
  text-align: center;
}

.blog-link-sec h3 {
  font-family: 'Noto Serif JP', serif;
  font-size: 24px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 12px;
}

.blog-link-sec p {
  font-size: 14px;
  color: var(--muted);
  margin-bottom: 32px;
  line-height: 2;
}

.blog-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--orange);
  color: white;
  font-weight: 700;
  font-size: 16px;
  padding: 16px 36px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.2s;
  box-shadow: 0 4px 16px rgba(217,95,43,0.3);
}

.blog-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(217,95,43,0.4);
}

/* FOOTER */
footer {
  background: var(--ink);
  color: rgba(255,255,255,0.4);
  text-align: center;
  padding: 40px 24px;
  font-size: 12px;
}

footer a { color: var(--light-warm); text-decoration: none; }

.footer-links {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

/* SCROLL REVEAL */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.reveal.on { opacity: 1; transform: none; }

/* RESPONSIVE */
@media (max-width: 720px) {
  nav { display: none; }
  .hero-inner { grid-template-columns: 1fr; }
  .hero-logo-area { width: 200px; margin: 0 auto; }
  .about { grid-template-columns: 1fr; }
  .profile-box { position: static; }
  .for-you-cards { grid-template-columns: 1fr; }
  .ba-grid { grid-template-columns: 1fr; }
  .ba-arrow-cell { transform: rotate(90deg); }
  .scene-inner { grid-template-columns: 1fr; }
  .scene-img-float { display: none; }
  .topic-grid { grid-template-columns: 1fr; }
}
</style>
</head>
