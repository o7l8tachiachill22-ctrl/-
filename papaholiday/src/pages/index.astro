---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>パパの週末DIYブログ</h1>
				<p>
					どうも、週末だけDIYを楽しむパパです。<br />
					初心者目線で工具・材料を正直レビュー。失敗談もそのまま載せてます。
				</p>
				<div class="tags">
					<span class="tag">🔨 工具レビュー</span>
					<span class="tag">🪵 DIY初心者</span>
					<span class="tag">🛒 Amazon・楽天</span>
				</div>
			</section>

			<section class="posts">
				<h2>最新記事</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img src={post.data.heroImage} alt="" />
									)}
									<div class="post-info">
										<h3>{post.data.title}</h3>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<p class="description">{post.data.description}</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.hero {
		text-align: center;
		padding: 2em 0 3em;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2em;
	}
	.hero h1 {
		font-size: 2em;
		margin-bottom: 0.5em;
	}
	.hero p {
		color: rgb(var(--gray));
		line-height: 1.8;
	}
	.tags {
		display: flex;
		gap: 0.5em;
		justify-content: center;
		flex-wrap: wrap;
		margin-top: 1em;
	}
	.tag {
		background: rgb(var(--gray-light));
		padding: 0.3em 0.8em;
		border-radius: 20px;
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
	}
	.posts h2 {
		font-size: 1.4em;
		margin-bottom: 1em;
		border-left: 4px solid var(--accent);
		padding-left: 0.5em;
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5em;
	}
	ul li a {
		display: flex;
		gap: 1em;
		text-decoration: none;
		color: inherit;
		padding: 1em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		transition: box-shadow 0.2s;
	}
	ul li a:hover {
		box-shadow: var(--box-shadow);
	}
	ul li a img {
		width: 120px;
		height: 80px;
		object-fit: cover;
		border-radius: 6px;
		flex-shrink: 0;
	}
	.post-info {
		flex: 1;
	}
	.post-info h3 {
		font-size: 1em;
		margin-bottom: 0.2em;
		color: rgb(var(--black));
	}
	.date {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin: 0 0 0.3em;
	}
	.description {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
